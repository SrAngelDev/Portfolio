---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Cursor from "../components/Cursor.astro";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Ángel Sánchez — Desarrollador Full Stack",
	description = "Portfolio de Ángel Sánchez, desarrollador Full Stack especializado en C#/.NET, Angular y Java/Spring Boot. Diseño limpio, código mantenible.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#F6FAFD" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content="https://srangeldev.es" />
		<meta property="og:locale" content="es_ES" />
		<link rel="canonical" href="https://srangeldev.es" />

		<!-- Mark JS available BEFORE first paint so motion CSS can hide reveals.
		     If JS fails, content stays visible (graceful degradation). -->
		<script is:inline>
			document.documentElement.classList.add("js-motion");
			if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
				document.documentElement.classList.add("reduce-motion");
			}
		</script>
	</head>
	<body>
		<!-- Ambient: soft blue washes + dot grid -->
		<div class="fixed inset-0 -z-50 overflow-hidden pointer-events-none" aria-hidden="true">
			<div
				class="absolute -top-40 -right-32 w-[640px] h-[640px] rounded-full bg-[#B3CFE5] opacity-40 blur-[160px]"
				style="animation: float-slow 18s ease-in-out infinite;"
			></div>
			<div
				class="absolute top-[60%] -left-40 w-[520px] h-[520px] rounded-full bg-[#4A7FA7] opacity-15 blur-[140px]"
				style="animation: float-slow 22s ease-in-out infinite 3s;"
			></div>
			<div class="absolute inset-0 dot-grid opacity-60"></div>
		</div>

		<Cursor />
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />

		<script>
			import "../scripts/motion/index";
		</script>
		<script src="../scripts/scroll.js"></script>
	</body>
</html>
