---
const navItems = [
  { name: "Experiencia", url: "/#experiencia" },
  { name: "Proyectos", url: "/#proyectos" },
  { name: "Stack", url: "/#stack" },
  { name: "Contacto", url: "/#contacto" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[#FAFAFA]/75 backdrop-blur-lg border-b border-[#E2E8F0]">
  <div class="container">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="font-display font-bold text-base tracking-tight text-[#0F172A]">
        Ángel<span class="text-[#4F46E5]">.</span>dev
      </a>
      <div class="hidden sm:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.url}
            class="px-3 py-2 text-sm text-[#64748B] hover:text-[#0F172A] font-medium transition-colors rounded-md hover:bg-[#F1F5F9]"
          >
            {item.name}
          </a>
        ))}
        <div class="w-px h-5 bg-[#E2E8F0] mx-2"></div>
        <a href="mailto:srangeldev@gmail.com" class="btn btn-primary py-2 px-4 text-xs">
          Email
        </a>
      </div>

      <!-- Mobile -->
      <div class="sm:hidden flex items-center gap-3">
        <a href="mailto:srangeldev@gmail.com" class="text-sm font-medium text-[#4F46E5]">Email</a>
      </div>
    </div>
  </div>
</nav>
