---
interface Props {
  number: string;
  title: string;
  description: string;
  url: string;
  tags: string[];
  year?: string;
}

const { number, title, description, url, tags, year = "2024" } = Astro.props;
---

<a href={url} class="group block" data-cursor="hover" data-tilt data-tilt-max="5">
  <article class="card relative p-7 md:p-9 h-full overflow-hidden transition-all duration-500 hover:-translate-y-1">
    <!-- Big background number -->
    <span
      class="absolute -top-6 -right-2 font-display font-bold text-[10rem] md:text-[12rem] leading-none text-[#1A3D63] opacity-[0.06] select-none pointer-events-none transition-all duration-500 group-hover:opacity-[0.10] group-hover:scale-105"
      aria-hidden="true"
    >
      {number}
    </span>

    <div class="relative z-10 flex flex-col h-full">
      <!-- Meta row -->
      <div class="flex items-center justify-between mb-8">
        <span class="text-xs font-mono text-[#4A7FA7] tracking-[0.14em] uppercase">
          / {year}
        </span>
        <span class="flex items-center gap-1.5 text-[10px] font-mono text-[#7895AE] tracking-[0.12em] uppercase">
          <span class="w-1.5 h-1.5 rounded-full bg-[#2F7D4F]"></span>
          Activo
        </span>
      </div>

      <!-- Title -->
      <h3 class="text-2xl md:text-[1.75rem] font-bold font-display text-[#0A1931] leading-tight mb-3 group-hover:text-[#1A3D63] transition-colors duration-300">
        {title}
      </h3>

      <!-- Description -->
      <p class="text-[#4A6A87] text-sm md:text-base leading-relaxed mb-7 flex-grow">
        {description}
      </p>

      <!-- Tags + arrow -->
      <div class="flex items-end justify-between gap-4 pt-6 border-t border-[rgba(26,61,99,0.08)]">
        <div class="flex flex-wrap gap-1.5">
          {
            tags.map((tag) => (
              <span class="px-2.5 py-1 text-[11px] font-mono tracking-tight rounded-full bg-[#EEF4FA] text-[#1A3D63] border border-[rgba(26,61,99,0.08)]">
                {tag}
              </span>
            ))
          }
        </div>
        <div
          class="shrink-0 w-11 h-11 rounded-full bg-[#1A3D63] flex items-center justify-center text-white transition-all duration-500 group-hover:bg-[#0A1931] group-hover:rotate-[-45deg]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </div>
    </div>
  </article>
</a>
