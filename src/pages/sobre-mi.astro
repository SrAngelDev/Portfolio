---
import Layout from "../layouts/Layout.astro";

const timeline = [
  {
    year: "2024",
    title: "Desarrollador Full Stack — OriginPath",
    description:
      "Lidero el desarrollo de soluciones empresariales sobre Angular y C#/.NET. Diseño la arquitectura, escribo el código y cuido los despliegues.",
  },
  {
    year: "2023",
    title: "Backend en sistemas FiveM",
    description:
      "Construyo backends Lua/Node.js para servidores de roleplay con alta concurrencia. Aprendí a optimizar latencia y consultas en producción real.",
  },
  {
    year: "2022",
    title: "Primeros pasos profesionales",
    description:
      "Empiezo en proyectos reales combinando formación y práctica. Descubro que me apasiona ver software propio funcionando en manos de usuarios.",
  },
  {
    year: "2021",
    title: "Aprendizaje constante",
    description:
      "Formación oficial en desarrollo de aplicaciones. Construyo proyectos personales para entender cómo encajan las piezas de extremo a extremo.",
  },
];

const philosophy = [
  {
    title: "Claridad antes que cleverness",
    description:
      "Un código que se entiende a la primera siempre vale más que un truco ingenioso. Escribo pensando en quien lo leerá dentro de seis meses.",
  },
  {
    title: "Hecho > perfecto",
    description:
      "Prefiero entregar pronto y mejorar con feedback real. La perfección suele ser una excusa para no terminar.",
  },
  {
    title: "Aprender en público",
    description:
      "Cada proyecto enseña algo. Documento lo que pruebo, comparto lo que aprendo, y dejo el código en mejor estado del que lo encontré.",
  },
  {
    title: "Detalles que importan",
    description:
      "Un buen producto se nota en los detalles: una transición fluida, un error claro, una API consistente. Ahí es donde está la diferencia.",
  },
];

const formacion = [
  {
    title: "Desarrollo de Aplicaciones Multiplataforma",
    place: "Formación Profesional Superior",
    years: "2021 — 2023",
  },
  {
    title: "Especialización Full Stack",
    place: "Cursos y certificaciones independientes",
    years: "2022 — actualidad",
  },
];
---

<Layout
  title="Sobre mí — Ángel Sánchez"
  description="Conoce a Ángel Sánchez: desarrollador Full Stack, su trayectoria, su forma de trabajar y su filosofía de código."
>
  <!-- HERO -->
  <section class="relative pt-36 md:pt-44 pb-20 md:pb-24">
    <div class="container">
      <div class="max-w-4xl reveal">
        <div class="section-label mb-8"><span>Sobre mí · v2025</span></div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-[5.5rem] font-bold font-display tracking-[-0.025em] leading-[0.95] text-[#0A1931]">
          Detrás del<br />
          <span class="text-gradient">código</span>, una<br />
          forma de pensar.
        </h1>
        <p class="text-lg md:text-xl text-[#4A6A87] mt-8 max-w-2xl leading-relaxed">
          Soy desarrollador, pero antes que eso soy alguien al que le gusta
          entender cómo funcionan las cosas. Esta es mi historia, mi enfoque
          y por qué hago lo que hago.
        </p>
      </div>
    </div>
  </section>

  <!-- TRAYECTORIA -->
  <section class="relative py-20 md:py-28 bg-[#EEF4FA]/60 border-y border-[rgba(26,61,99,0.06)]">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <!-- Sticky heading -->
        <aside class="lg:col-span-4 lg:sticky lg:top-32 lg:self-start reveal">
          <div class="section-label mb-5"><span>Trayectoria</span></div>
          <h2 class="text-4xl md:text-5xl font-bold font-display tracking-[-0.025em] leading-[1.05] text-[#0A1931]">
            De la curiosidad<br />a la profesión.
          </h2>
          <p class="text-[#4A6A87] mt-5 leading-relaxed">
            Cuatro hitos que me han traído hasta aquí. No es una lista
            completa, pero sí los puntos que mejor explican el camino.
          </p>
        </aside>

        <!-- Timeline -->
        <ol class="lg:col-span-8 relative space-y-10 lg:space-y-12 border-l border-[rgba(26,61,99,0.12)] pl-8 md:pl-10">
          {
            timeline.map((item) => (
              <li class="relative reveal">
                <span class="absolute -left-[42px] md:-left-[50px] top-1 flex items-center justify-center w-6 h-6 rounded-full bg-white border border-[rgba(26,61,99,0.15)]">
                  <span class="w-2 h-2 rounded-full bg-[#1A3D63]" />
                </span>
                <div class="flex items-baseline gap-4 mb-2">
                  <span class="text-xs font-mono text-[#4A7FA7] tracking-[0.14em] uppercase">
                    / {item.year}
                  </span>
                </div>
                <h3 class="text-xl md:text-2xl font-semibold font-display text-[#0A1931] leading-snug mb-2">
                  {item.title}
                </h3>
                <p class="text-[#4A6A87] leading-relaxed">{item.description}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- FILOSOFÍA -->
  <section class="relative py-24 md:py-32">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <div class="section-label mb-5 justify-center"><span>Cómo trabajo</span></div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-display tracking-[-0.025em] leading-[1] text-[#0A1931]">
          Cuatro ideas<br />que me <span class="text-gradient">guían.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 max-w-5xl mx-auto">
        {
          philosophy.map((p, i) => (
            <div class="card p-7 md:p-8 reveal">
              <div class="flex items-baseline gap-4 mb-4">
                <span class="text-3xl md:text-4xl font-bold font-display text-[#1A3D63] opacity-30">
                  0{i + 1}
                </span>
                <h3 class="text-xl md:text-2xl font-semibold font-display text-[#0A1931] leading-snug">
                  {p.title}
                </h3>
              </div>
              <p class="text-[#4A6A87] leading-relaxed">{p.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FORMACIÓN -->
  <section class="relative py-24 md:py-32 bg-[#EEF4FA]/60 border-y border-[rgba(26,61,99,0.06)]">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 reveal">
          <div class="section-label mb-5"><span>Formación</span></div>
          <h2 class="text-4xl md:text-5xl font-bold font-display tracking-[-0.025em] leading-[1.05] text-[#0A1931]">
            Aprender no<br />se acaba.
          </h2>
          <p class="text-[#4A6A87] mt-5 leading-relaxed max-w-md">
            La tecnología cambia rápido; las bases bien puestas, no. Mantengo
            la formación viva entre lo formal y la práctica diaria.
          </p>
        </div>

        <div class="lg:col-span-7 space-y-4 reveal">
          {
            formacion.map((f) => (
              <div class="card p-6 md:p-7 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                <div>
                  <h3 class="text-lg md:text-xl font-semibold font-display text-[#0A1931]">
                    {f.title}
                  </h3>
                  <p class="text-sm text-[#4A6A87] mt-1">{f.place}</p>
                </div>
                <span class="text-xs font-mono text-[#4A7FA7] tracking-[0.14em] uppercase whitespace-nowrap">
                  {f.years}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-24 md:py-32">
    <div class="container">
      <div class="card p-10 md:p-16 text-center max-w-4xl mx-auto reveal">
        <div class="section-label mb-5 justify-center"><span>¿Conectamos?</span></div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-display tracking-[-0.025em] leading-[1] text-[#0A1931]">
          Vamos a construir<br /><span class="text-gradient">algo bueno.</span>
        </h2>
        <p class="text-[#4A6A87] text-base md:text-lg mt-6 max-w-xl mx-auto">
          Si llegaste hasta aquí, probablemente tengamos algo en común.
          Cuéntame qué tienes en mente.
        </p>
        <div class="flex flex-wrap gap-3 mt-10 justify-center">
          <a href="mailto:srangeldev@gmail.com" class="btn btn-primary">
            Escríbeme
          </a>
          <a href="/#proyectos" class="btn btn-secondary">
            Ver proyectos
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
