---
interface Props {
  photo?: string;
}
const { photo } = Astro.props;
---

<section class="pt-32 pb-20 md:pb-28 relative overflow-hidden">
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-32 w-[600px] h-[600px] rounded-full bg-[#EEF2FF] opacity-50 blur-[120px]"></div>
    <div class="absolute -bottom-40 -left-32 w-[500px] h-[500px] rounded-full bg-[#E2E8F0] opacity-40 blur-[120px]"></div>
  </div>
  <div class="container">
    <div class="flex flex-col md:flex-row md:items-center gap-10 md:gap-16">
      <div class="flex-1 min-w-0">
        <div class="fade-in">
          <span class="section-label">Portfolio</span>
        </div>
        <h1 class="fade-in text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-bold tracking-[-0.04em] leading-[0.9]">
          Ángel<br />
          <span class="text-gradient">Sánchez</span>
        </h1>
        <p class="fade-in text-lg sm:text-xl text-[#475569] mt-5 max-w-lg leading-relaxed" style="transition-delay: 100ms">
          Desarrollador Full Stack especializado en <strong class="text-[#0F172A]">.NET</strong>,
          <strong class="text-[#0F172A]">Angular</strong> y
          <strong class="text-[#0F172A]">Java</strong>.
          Código limpio, productos que escalan.
        </p>
        <div class="fade-in flex flex-wrap gap-3 mt-8" style="transition-delay: 200ms">
          <a href="#proyectos" class="btn btn-primary">
            Ver proyectos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="mailto:srangeldev@gmail.com" class="btn btn-secondary">
            Contacto
          </a>
          <a href="https://github.com/SrAngelDev" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>

        <div class="fade-in flex items-center gap-4 mt-10 text-sm text-[#64748B]" style="transition-delay: 300ms">
          <span class="flex items-center gap-2">
            <span class="relative flex w-2 h-2">
              <span class="absolute inline-flex h-full w-full rounded-full bg-[#22C55E] opacity-60 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[#22C55E]"></span>
            </span>
            Disponible para proyectos
          </span>
          <span class="w-px h-4 bg-[#CBD5E1]"></span>
          <span>Madrid · Remoto</span>
        </div>
      </div>

      {
        photo && (
          <div class="shrink-0 fade-in flex flex-col items-center md:items-end" style="transition-delay: 150ms">
            <div class="relative w-full max-w-[280px] md:max-w-[340px]">
              <!-- Gradient border ring -->
              <div class="absolute -inset-[3px] rounded-2xl bg-gradient-to-br from-[#4F46E5] via-[#6366F1] to-[#1E293B]"></div>
              <!-- Actual photo -->
              <div class="relative rounded-2xl overflow-hidden border-2 border-white shadow-2xl shadow-[#1E293B]/20 bg-[#F1F5F9]">
                <img
                  src={photo}
                  alt="Ángel Sánchez"
                  class="w-full h-auto block"
                />
              </div>
              <!-- Decorative corner accents -->
              <div class="absolute -bottom-3 -right-3 w-8 h-8 border-r-[3px] border-b-[3px] border-[#4F46E5] rounded-br-lg opacity-40"></div>
              <div class="absolute -top-3 -left-3 w-8 h-8 border-t-[3px] border-l-[3px] border-[#4F46E5] rounded-tl-lg opacity-40"></div>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
