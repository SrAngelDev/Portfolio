---
import Layout from "../../layouts/Layout.astro";

const stack = ["Angular", "TypeScript", "C# / .NET", "SQL Server", "Azure", "Docker"];

const features = [
  {
    title: "Gestión de procesos",
    description: "Flujos configurables para que cada departamento adapte la herramienta a su forma de trabajar sin depender del equipo de desarrollo.",
  },
  {
    title: "Trazabilidad end-to-end",
    description: "Cada acción queda registrada. Auditorías, métricas y reportes con datos reales y filtrables al instante.",
  },
  {
    title: "Roles y permisos finos",
    description: "Sistema granular por módulo y por acción. Lo justo para cada usuario, sin fricción innecesaria.",
  },
  {
    title: "Despliegue continuo",
    description: "Pipelines automatizados con tests, build y publicación. Iteraciones rápidas y seguras.",
  },
];

const milestones = [
  { label: "Módulos en producción", value: "12+" },
  { label: "Usuarios activos", value: "200+" },
  { label: "Tiempo de respuesta", value: "<200ms" },
];
---

<Layout title="OriginPath — Aplicaciones empresariales" description="Caso de estudio: OriginPath, plataforma empresarial de gestión y trazabilidad construida con Angular y C#/.NET.">
  <section class="pt-32 pb-16">
    <div class="container">
      <a href="/#proyectos" class="inline-flex items-center gap-1.5 text-sm text-[#94A3B8] hover:text-[#4F46E5] transition-colors mb-8 fade-in">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Volver
      </a>
      <div class="fade-in">
        <div class="flex items-center gap-3 mb-6">
          <span class="section-label">Caso de estudio</span>
          <span class="text-xs font-mono text-[#94A3B8]">/ 2024</span>
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold tracking-tight leading-[0.95] text-[#0F172A]">OriginPath</h1>
        <p class="text-lg text-[#475569] mt-3 max-w-2xl leading-relaxed">
          Plataforma empresarial de gestión y trazabilidad. Una aplicación a medida para optimizar
          procesos internos y centralizar la información de varios departamentos.
        </p>
        <div class="flex flex-wrap gap-2 mt-6">
          {stack.map((t) => (<span class="tag">{t}</span>))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-[#F8FAFC] border-y border-[#E2E8F0]">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {milestones.map((m) => (
          <div class="text-center fade-in">
            <div class="text-3xl md:text-4xl font-display font-bold text-[#1E293B]">{m.value}</div>
            <div class="text-xs text-[#94A3B8] uppercase tracking-wider mt-1">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
        <div class="md:col-span-2 fade-in">
          <span class="section-label">El reto</span>
          <h2 class="text-2xl sm:text-3xl font-display font-bold tracking-tight text-[#0F172A]">Empresa creciendo, procesos por todas partes.</h2>
        </div>
        <div class="md:col-span-3 space-y-4 fade-in">
          <p class="text-[#475569] leading-relaxed">La empresa tenía la información dispersa entre hojas de cálculo, correos y herramientas distintas. Cada departamento tenía su modo de trabajar y la trazabilidad entre ellos era prácticamente manual.</p>
          <p class="text-[#475569] leading-relaxed">Necesitaban una plataforma única, fácil de adoptar y que pudiera crecer con el negocio.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-[#F8FAFC] border-y border-[#E2E8F0]">
    <div class="container">
      <div class="max-w-2xl mb-10 fade-in">
        <span class="section-label">Lo que construí</span>
        <h2 class="text-3xl font-display font-bold tracking-tight text-[#0F172A]">Una plataforma modular, pensada para escalar.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {features.map((f, i) => (
          <div class="card p-6 fade-in">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="text-2xl font-display font-bold text-[#94A3B8]">0{i + 1}</span>
              <h3 class="text-lg font-semibold text-[#0F172A]">{f.title}</h3>
            </div>
            <p class="text-sm text-[#475569] leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
        <div class="md:col-span-2 fade-in">
          <span class="section-label">Aprendizajes</span>
          <h2 class="text-2xl sm:text-3xl font-display font-bold tracking-tight text-[#0F172A]">Lo que me llevo de este proyecto.</h2>
        </div>
        <div class="md:col-span-3 space-y-4 fade-in">
          <p class="text-[#475569] leading-relaxed">Trabajar con un cliente real obliga a tomar decisiones de arquitectura con sentido común. No siempre la solución más elegante es la correcta: lo importante es que el equipo pueda mantenerla cuando yo no esté.</p>
          <p class="text-[#475569] leading-relaxed">La capa de permisos fue uno de los puntos más interesantes: granular sin volverse impredecible. Y los pipelines de despliegue me han devuelto horas cada semana.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container">
      <div class="card p-8 md:p-12 text-center max-w-2xl mx-auto fade-in hover:border-[#4F46E5]/30">
        <h2 class="text-2xl sm:text-3xl font-display font-bold tracking-tight text-[#0F172A] mb-3">¿Necesitas algo parecido?</h2>
        <p class="text-sm text-[#475569] mb-6">Si tu equipo tiene los procesos repartidos, hablemos.</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="mailto:srangeldev@gmail.com" class="btn btn-primary">Escríbeme</a>
          <a href="/#proyectos" class="btn btn-secondary">Otros proyectos</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
