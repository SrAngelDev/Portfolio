---
import Layout from "../../layouts/Layout.astro";

const stack = ["Lua", "Node.js", "MySQL", "Redis", "Docker", "Linux"];

const modules = [
  {
    title: "Economía y banca",
    description: "Sistema económico cerrado con cuentas, transferencias, intereses y persistencia atómica. Sin race conditions, sin dinero perdido.",
  },
  {
    title: "Inventario y peso",
    description: "Inventario por slots con peso, stack y categorías. Sincronización servidor-cliente optimizada para evitar exploits y desincronizaciones.",
  },
  {
    title: "Sistema de jobs",
    description: "Trabajos configurables con grados, nómina, vehículos asignados y zonas. Pensado para que los administradores no toquen código.",
  },
  {
    title: "Panel de administración",
    description: "Dashboard web con logs en tiempo real, gestión de jugadores, vista de economía y reportes.",
  },
];

const stats = [
  { label: "Jugadores simultáneos", value: "150+" },
  { label: "Tick rate", value: "60Hz" },
  { label: "Uptime mensual", value: "99.7%" },
];
---

<Layout title="Sistema de gestión FiveM" description="Caso de estudio: backend completo para servidor de roleplay FiveM con economía, inventario, jobs y panel de admin.">
  <section class="pt-32 pb-16">
    <div class="container">
      <a href="/#proyectos" class="inline-flex items-center gap-1.5 text-sm text-[#94A3B8] hover:text-[#4F46E5] transition-colors mb-8 fade-in">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Volver
      </a>
      <div class="fade-in">
        <div class="flex items-center gap-3 mb-6">
          <span class="section-label">Caso de estudio</span>
          <span class="text-xs font-mono text-[#94A3B8]">/ 2023</span>
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold tracking-tight leading-[0.95] text-[#0F172A]">Sistema de gestión FiveM</h1>
        <p class="text-lg text-[#475569] mt-3 max-w-2xl leading-relaxed">Backend completo para servidores de roleplay en FiveM: economía, inventarios, jobs, vehículos y un panel web. Pensado para alta concurrencia y latencia baja.</p>
        <div class="flex flex-wrap gap-2 mt-6">
          {stack.map((t) => (<span class="tag">{t}</span>))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-[#F8FAFC] border-y border-[#E2E8F0]">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {stats.map((s) => (
          <div class="text-center fade-in">
            <div class="text-3xl md:text-4xl font-display font-bold text-[#1E293B]">{s.value}</div>
            <div class="text-xs text-[#94A3B8] uppercase tracking-wider mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
        <div class="md:col-span-2 fade-in">
          <span class="section-label">El contexto</span>
          <h2 class="text-2xl sm:text-3xl font-display font-bold tracking-tight text-[#0F172A]">Roleplay serio, código serio.</h2>
        </div>
        <div class="md:col-span-3 space-y-4 fade-in">
          <p class="text-[#475569] leading-relaxed">Los servidores de roleplay en FiveM combinan un cliente de juego exigente con un servidor que tiene que aguantar 150+ jugadores simultáneos. Cada operación cuenta.</p>
          <p class="text-[#475569] leading-relaxed">El reto era construir un backend que diera estabilidad económica, inventario coherente y mecánicas justas — sin lag, sin exploits y sin perder datos al reiniciar.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-[#F8FAFC] border-y border-[#E2E8F0]">
    <div class="container">
      <div class="max-w-2xl mb-10 fade-in">
        <span class="section-label">Módulos clave</span>
        <h2 class="text-3xl font-display font-bold tracking-tight text-[#0F172A]">Cuatro sistemas, una arquitectura.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {modules.map((m, i) => (
          <div class="card p-6 fade-in">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="text-2xl font-display font-bold text-[#94A3B8]">0{i + 1}</span>
              <h3 class="text-lg font-semibold text-[#0F172A]">{m.title}</h3>
            </div>
            <p class="text-sm text-[#475569] leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
        <div class="md:col-span-2 fade-in">
          <span class="section-label">Decisiones técnicas</span>
          <h2 class="text-2xl sm:text-3xl font-display font-bold tracking-tight text-[#0F172A]">Lo invisible es lo importante.</h2>
        </div>
        <div class="md:col-span-3 space-y-4 fade-in">
          <p class="text-[#475569] leading-relaxed"><strong class="text-[#0F172A]">MySQL</strong> como fuente de verdad y <strong class="text-[#0F172A]">Redis</strong> como caché de sesión: consultas frecuentes a milisegundos y persistencia robusta.</p>
          <p class="text-[#475569] leading-relaxed">Comunicación cliente-servidor minimizada — sólo se envía lo necesario. Los exploits clásicos del roleplay se cierran en la capa servidor, no en el cliente.</p>
          <p class="text-[#475569] leading-relaxed">Todo dockerizado, logs centralizados y despliegue desde GitHub. Si algo falla a las 3 de la mañana, no hace falta entrar al servidor para entender qué pasó.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container">
      <div class="card p-8 md:p-12 text-center max-w-2xl mx-auto fade-in hover:border-[#4F46E5]/30">
        <h2 class="text-2xl sm:text-3xl font-display font-bold tracking-tight text-[#0F172A] mb-3">¿Tienes un proyecto en mente?</h2>
        <p class="text-sm text-[#475569] mb-6">Si necesitas un backend o algo parecido, podemos hablar.</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="mailto:srangeldev@gmail.com" class="btn btn-primary">Contacto</a>
          <a href="/#proyectos" class="btn btn-secondary">Otros proyectos</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
