---
interface Props {
  title: string;
  desc: string;
  tags: string[];
  url: string;
  year?: string;
  index?: number;
}

const { title, desc, tags, url, year, index = 0 } = Astro.props;
---

<a
  href={url}
  target={url.startsWith("http") ? "_blank" : undefined}
  rel={url.startsWith("http") ? "noopener noreferrer" : undefined}
  class="fade-in block group"
  style={`transition-delay: ${index * 80}ms`}
>
  <article class="card p-6 sm:p-8 relative overflow-hidden hover:border-[#4F46E5]/30 transition-all duration-300">
    <div class="absolute top-0 left-0 w-1 h-0 bg-gradient-to-b from-[#4F46E5] to-[#6366F1] transition-all duration-300 group-hover:h-full"></div>
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-2">
          <h3 class="font-display font-semibold text-lg sm:text-xl text-[#0F172A] group-hover:text-[#4F46E5] transition-colors">
            {title}
          </h3>
          {year && <span class="text-[10px] font-mono text-[#94A3B8] uppercase tracking-wider">{year}</span>}
        </div>
        <p class="text-sm text-[#475569] leading-relaxed">{desc}</p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          {tags.map((tag) => (
            <span class="tag text-[10px]">{tag}</span>
          ))}
        </div>
      </div>
      <div class="shrink-0 self-end sm:self-center">
        <div class="w-10 h-10 rounded-full bg-[#F1F5F9] border border-[#E2E8F0] flex items-center justify-center text-[#475569] group-hover:bg-[#4F46E5] group-hover:text-white group-hover:border-[#4F46E5] transition-all duration-300 group-hover:-translate-y-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </div>
    </div>
  </article>
</a>
