---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Página no encontrada" description="La página que buscas no existe o fue movida.">
  <section class="min-h-[70vh] flex items-center pt-20 pb-20">
    <div class="container">
      <div class="max-w-lg mx-auto text-center fade-in">
        <div class="text-8xl sm:text-9xl font-display font-bold tracking-tight text-[#E2E8F0] leading-none mb-4">404</div>
        <h1 class="text-2xl sm:text-3xl font-display font-bold text-[#0F172A] mb-3">Página no encontrada</h1>
        <p class="text-sm text-[#64748B] mb-8">La ruta que buscas no existe, fue movida o nunca llegó a existir.</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/" class="btn btn-primary">Volver al inicio</a>
          <a href="/#proyectos" class="btn btn-secondary">Ver proyectos</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
