---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import Timeline from "../components/Timeline.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillGrid from "../components/SkillGrid.astro";
import ContactSection from "../components/ContactSection.astro";

const experience = [
  {
    year: "2026",
    role: "Modelado de Datos",
    company: "BBVA — Sector Financiero",
    desc: "Diseño y modelado de bases de datos para gestión de información financiera. Creación de modelos eficientes y escalables, optimización de consultas SQL, y colaboración con equipos de desarrollo para asegurar la calidad e integridad de los datos.",
    tags: ["SQL Server", "MySQL", "Optimización", "Documentación"],
  },
  {
    year: "2026",
    role: "Proyecto Fin de Grado — NexoPostal",
    company: "Plataforma logística end-to-end",
    desc: "Arquitectura de microservicios con 3 SPAs Angular + 5 servicios .NET, bases de datos independientes y pipeline CI/CD completa. Stripe Checkout, SignalR, GPS tracking y despliegue automatizado con Docker y GitHub Actions.",
    tags: ["Angular", ".NET", "PostgreSQL", "Docker", "CI/CD"],
  },
  {
    year: "2025",
    role: "Desarrollador Full Stack",
    company: "OriginPath — FCT (DAW)",
    desc: "Creación de componentes reutilizables en Angular, desarrollo backend en C# (.NET) con Entity Framework Core y SQL Server. Aplicación de principios SOLID, patrones DTO e inyección de dependencias en entorno profesional.",
    tags: ["Angular", "C#", ".NET", "SQL Server"],
  },
  {
    year: "2018-2023",
    role: "Full Stack Developer — FiveM",
    company: "Sistemas de gestión para servidores roleplay",
    desc: "Desarrollo completo de módulos para servidores con 500+ usuarios diarios. Sistemas de economía, inventarios, jobs y panel de administración. Optimización al 100% con Lua, Node.js, MySQL y Redis.",
    tags: ["Lua", "Node.js", "MySQL", "Redis"],
  },
];

const projects = [
  {
    title: "Trabajo Final de Grado — NexoPostal",
    desc: "Plataforma logística end-to-end con microservicios, 3 SPAs Angular y CI/CD completo. En producción en nexopostal.es.",
    tags: ["Angular", ".NET", "PostgreSQL", "Docker"],
    url: "https://github.com/SrAngelDev/NexoPostal",
    year: "2026",
  },
  {
    title: "OriginPath",
    desc: "Plataforma empresarial de gestión y trazabilidad con Angular y C#/.NET para procesos internos empresariales.",
    tags: ["Angular", "C#", ".NET", "SQL Server"],
    url: "/proyectos/aplicaciones-empresariales-originpath",
    year: "2025",
  },
  {
    title: "FiveM · Gestión",
    desc: "Backend para servidores roleplay con economía, inventarios y panel admin. 150+ jugadores concurrentes.",
    tags: ["Lua", "Node.js", "MySQL", "Redis"],
    url: "/proyectos/sistema-gestion-fivem",
    year: "2023",
  },
];

const skillGroups = [
  {
    title: "Backend",
    skills: [
      { name: "C# / .NET", icon: "csharp" },
      { name: "Java / Spring", icon: "spring" },
      { name: "Node.js", icon: "nodejs" },
      { name: "Kotlin", icon: "kotlin" },
    ],
  },
  {
    title: "Frontend",
    skills: [
      { name: "Angular", icon: "angular" },
      { name: "TypeScript", icon: "typescript" },
      { name: "Astro", icon: "astro" },
      { name: "Tailwind CSS", icon: "tailwind" },
      { name: "Bootstrap", icon: "bootstrap" },
    ],
  },
  {
    title: "Bases de Datos",
    skills: [
      { name: "PostgreSQL", icon: "postgresql" },
      { name: "SQL Server", icon: "sqlserver" },
      { name: "MongoDB", icon: "mongodb" },
      { name: "Redis", icon: "redis" },
    ],
  },
  {
    title: "DevOps & Tools",
    skills: [
      { name: "Docker", icon: "docker" },
      { name: "GitHub Actions", icon: "githubactions" },
      { name: "Git", icon: "git" },
      { name: "Linux", icon: "linux" },
    ],
  },
];
---

<Layout>
  <HeroSection photo="/foto.png" />

  <!-- Experience -->
  <section id="experiencia" class="py-20 md:py-28 bg-[#F8FAFC] border-y border-[#E2E8F0]">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10 md:gap-16">
        <div class="md:col-span-2 fade-in">
          <span class="section-label">Experiencia</span>
          <h2 class="text-3xl sm:text-4xl font-display font-bold tracking-tight text-[#0F172A]">
            Trayectoria
          </h2>
          <p class="text-sm text-[#64748B] mt-3 leading-relaxed">
            De la formación a la producción. Cada proyecto me ha enseñado algo
            que llevo al siguiente.
          </p>
        </div>
        <div class="md:col-span-3">
          <Timeline items={experience} />
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="proyectos" class="py-20 md:py-28">
    <div class="container">
      <div class="mb-12 fade-in">
        <span class="section-label">Proyectos</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold tracking-tight text-[#0F172A]">
          Trabajo seleccionado
        </h2>
        <p class="text-sm text-[#64748B] mt-3 max-w-lg">
          Una muestra de lo que he construido recientemente. Cada uno resuelve
          un problema real con tecnologías pensadas para durar.
        </p>
      </div>
      <div class="grid gap-4">
        {projects.map((p, i) => (
          <ProjectCard {...p} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="stack" class="py-20 md:py-28 bg-[#F8FAFC] border-y border-[#E2E8F0]">
    <div class="container">
      <div class="mb-12 fade-in">
        <span class="section-label">Stack</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold tracking-tight text-[#0F172A]">
          Tecnologías
        </h2>
        <p class="text-sm text-[#64748B] mt-3 max-w-lg">
          Las herramientas que uso a diario, organizadas por área.
        </p>
      </div>
      <SkillGrid groups={skillGroups} />
    </div>
  </section>

  <!-- About -->
  <section class="py-20 md:py-28">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10 md:gap-16">
        <div class="md:col-span-2 fade-in">
          <span class="section-label">Sobre mí</span>
          <h2 class="text-3xl sm:text-4xl font-display font-bold tracking-tight text-[#0F172A]">
            Full Stack<br />con carácter
          </h2>
        </div>
        <div class="md:col-span-3 space-y-5 fade-in">
          <p class="text-[#475569] leading-relaxed">
            Graduado en <strong class="text-[#0F172A]">Desarrollo de Aplicaciones Web</strong>.
            Actualmente modelo datos en <strong class="text-[#0F172A]">BBVA</strong> y desarrollo
            soluciones full stack. Me especializo en ecosistemas <strong class="text-[#0F172A]">.NET</strong>
            y <strong class="text-[#0F172A]">Angular</strong>, con experiencia en arquitectura limpia,
            microservicios y CI/CD.
          </p>
          <p class="text-[#475569] leading-relaxed">
            Mi trabajo en <strong class="text-[#0F172A]">NexoPostal</strong> (TFG) y
            <strong class="text-[#0F172A]">OriginPath</strong> me ha dado visión end-to-end del
            producto: desde la base de datos hasta el despliegue, pasando por tests, monitoreo y
            documentación.
          </p>
          <div class="flex flex-wrap gap-8 pt-2 text-sm">
            <div>
              <span class="text-[#94A3B8] text-xs block mb-0.5">Ubicación</span>
              <span class="text-[#0F172A] font-medium">Madrid, España</span>
            </div>
            <div>
              <span class="text-[#94A3B8] text-xs block mb-0.5">Email</span>
              <a href="mailto:srangeldev@gmail.com" class="text-[#4F46E5] font-medium hover:underline">srangeldev@gmail.com</a>
            </div>
            <div>
              <span class="text-[#94A3B8] text-xs block mb-0.5">Idiomas</span>
              <span class="text-[#0F172A] font-medium">Español · Inglés C1</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactSection />
</Layout>
