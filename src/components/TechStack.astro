---
interface Props {
  name: string;
  icon: string;
  level?: string;
}

const { name, icon, level } = Astro.props;
---

<div class="group">
  <div
    class="relative card p-5 h-full text-center flex flex-col items-center gap-3 transition-all duration-300 hover:-translate-y-1 hover:border-[rgba(26,61,99,0.18)]"
  >
    <div
      class="w-14 h-14 rounded-xl bg-[#EEF4FA] flex items-center justify-center text-[#1A3D63] transition-all duration-300 group-hover:bg-[#1A3D63] group-hover:text-white"
    >
      <Fragment set:html={icon} />
    </div>

    <div>
      <h4 class="font-semibold font-display text-[#0A1931] text-sm leading-tight">
        {name}
      </h4>
      {
        level && (
          <p class="text-[10px] font-mono text-[#7895AE] uppercase tracking-[0.1em] mt-1">
            {level}
          </p>
        )
      }
    </div>
  </div>
</div>
