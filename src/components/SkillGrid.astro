---
import Icon from "./Icon.astro";

interface Skill {
  name: string;
  icon: string;
}

interface Props {
  groups: {
    title: string;
    skills: Skill[];
  }[];
}

const { groups } = Astro.props;
---

<div class="space-y-10">
  {groups.map((group, gi) => (
    <div class="fade-in" style={`transition-delay: ${gi * 100}ms`}>
      <h3 class="font-display font-semibold text-sm text-[#64748B] mb-4 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[#4F46E5]"></span>
        {group.title}
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {group.skills.map((skill, si) => (
          <div
            class="card p-4 flex items-center gap-3 hover:border-[#4F46E5]/30 transition-all duration-300 cursor-default group"
            style={`transition-delay: ${si * 30}ms`}
          >
            <div class="w-9 h-9 rounded-lg bg-[#F1F5F9] flex items-center justify-center text-[#475569] group-hover:bg-[#4F46E5] group-hover:text-white transition-all duration-300">
              <Icon name={skill.icon} size={18} />
            </div>
            <span class="text-sm font-medium text-[#0F172A]">{skill.name}</span>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>
