---
import Layout from "../../layouts/Layout.astro";

const stack = ["Lua", "Node.js", "MySQL", "Redis", "Docker", "Linux"];

const modules = [
  {
    title: "Economía y banca",
    description:
      "Sistema económico cerrado con cuentas, transferencias, intereses y persistencia atómica. Sin race conditions, sin dinero perdido.",
  },
  {
    title: "Inventario y peso",
    description:
      "Inventario por slots con peso, stack y categorías. Sincronización servidor-cliente optimizada para evitar exploits y desincronizaciones.",
  },
  {
    title: "Sistema de jobs",
    description:
      "Trabajos configurables con grados, nómina, vehículos asignados y zonas. Pensado para que los administradores no toquen código.",
  },
  {
    title: "Panel de administración",
    description:
      "Dashboard web con logs en tiempo real, gestión de jugadores, vista de economía y reportes. Construido con la misma stack del backend.",
  },
];

const stats = [
  { label: "Jugadores simultáneos", value: "150+" },
  { label: "Tick rate del servidor", value: "60Hz" },
  { label: "Uptime mensual", value: "99.7%" },
];
---

<Layout
  title="Sistema de gestión FiveM"
  description="Caso de estudio: backend completo para servidor de roleplay FiveM con economía, inventario, jobs y panel de admin."
>
  <!-- HERO -->
  <section class="relative pt-36 md:pt-44 pb-20">
    <div class="container">
      <a href="/#proyectos" class="inline-flex items-center gap-2 text-sm text-[#4A6A87] hover:text-[#0A1931] transition-colors mb-10 reveal">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a proyectos
      </a>

      <div class="max-w-4xl reveal">
        <div class="flex flex-wrap items-center gap-3 mb-8">
          <span class="section-label"><span>Caso de estudio · 02</span></span>
          <span class="text-xs font-mono text-[#7895AE] tracking-[0.14em] uppercase">/ 2023</span>
          <span class="inline-flex items-center gap-1.5 text-xs font-mono text-[#2F7D4F] tracking-[0.12em] uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-[#2F7D4F]"></span> Activo
          </span>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold font-display tracking-[-0.025em] leading-[0.95] text-[#0A1931]">
          Sistema de gestión<br />FiveM
        </h1>
        <p class="text-xl md:text-2xl font-display text-[#1A3D63] mt-3">
          Backend completo para servidores de roleplay.
        </p>
        <p class="text-lg text-[#4A6A87] mt-6 max-w-2xl leading-relaxed">
          Un conjunto de módulos en Lua y Node.js que dan vida a un servidor
          de FiveM: economía, inventarios, jobs, vehículos y un panel web.
          Pensado para alta concurrencia y latencia baja.
        </p>

        <div class="flex flex-wrap gap-2 mt-8">
          {stack.map((t) => (
            <span class="px-3 py-1.5 text-xs font-mono rounded-full bg-[#EEF4FA] text-[#1A3D63] border border-[rgba(26,61,99,0.08)]">
              {t}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="relative py-12 md:py-16 bg-[#EEF4FA]/60 border-y border-[rgba(26,61,99,0.06)]">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {stats.map((s) => (
          <div class="text-center reveal">
            <div class="text-4xl md:text-5xl font-bold font-display text-[#1A3D63]">{s.value}</div>
            <div class="text-xs font-mono text-[#7895AE] uppercase tracking-[0.12em] mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTEXTO -->
  <section class="relative py-24 md:py-32">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-4 reveal">
          <div class="section-label mb-5"><span>El contexto</span></div>
          <h2 class="text-3xl md:text-4xl font-bold font-display tracking-[-0.025em] leading-[1.1] text-[#0A1931]">
            Roleplay serio, código serio.
          </h2>
        </div>
        <div class="lg:col-span-8 space-y-5 reveal">
          <p class="text-lg text-[#4A6A87] leading-relaxed">
            Los servidores de roleplay en FiveM combinan un cliente de juego
            exigente con un servidor que tiene que aguantar 150+ jugadores
            simultáneos haciendo acciones constantemente. Cada operación cuenta.
          </p>
          <p class="text-[#4A6A87] leading-relaxed">
            El reto era construir un backend que diera estabilidad económica,
            inventario coherente y mecánicas justas — sin lag, sin exploits
            y sin perder datos al reiniciar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- MÓDULOS -->
  <section class="relative py-24 md:py-32 bg-[#EEF4FA]/60 border-y border-[rgba(26,61,99,0.06)]">
    <div class="container">
      <div class="max-w-3xl mb-14 reveal">
        <div class="section-label mb-5"><span>Módulos clave</span></div>
        <h2 class="text-4xl md:text-5xl font-bold font-display tracking-[-0.025em] leading-[1.05] text-[#0A1931]">
          Cuatro sistemas,<br />una arquitectura.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
        {modules.map((m, i) => (
          <div class="card p-7 md:p-8 reveal">
            <div class="flex items-baseline gap-4 mb-3">
              <span class="text-3xl font-bold font-display text-[#1A3D63] opacity-30">
                0{i + 1}
              </span>
              <h3 class="text-xl font-semibold font-display text-[#0A1931]">{m.title}</h3>
            </div>
            <p class="text-[#4A6A87] leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TÉCNICO -->
  <section class="relative py-24 md:py-32">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-5 reveal">
          <div class="section-label mb-5"><span>Decisiones técnicas</span></div>
          <h2 class="text-3xl md:text-4xl font-bold font-display tracking-[-0.025em] leading-[1.1] text-[#0A1931]">
            Lo invisible<br />es lo importante.
          </h2>
        </div>
        <div class="lg:col-span-7 space-y-5 reveal">
          <p class="text-[#4A6A87] leading-relaxed">
            <strong class="text-[#0A1931]">MySQL</strong> como fuente de verdad y
            <strong class="text-[#0A1931]">Redis</strong> como caché de sesión:
            consultas frecuentes a milisegundos y persistencia robusta.
            Transacciones atómicas en todo lo que toca dinero.
          </p>
          <p class="text-[#4A6A87] leading-relaxed">
            Comunicación cliente-servidor minimizada — sólo se envía lo
            necesario, cuando se necesita. Los exploits clásicos del roleplay
            (duplicación, teleport, money glitch) se cierran en la capa
            servidor, no en el cliente.
          </p>
          <p class="text-[#4A6A87] leading-relaxed">
            Todo dockerizado, logs centralizados y despliegue desde GitHub.
            Si algo falla a las 3 de la mañana, no hace falta entrar al servidor
            para entender qué pasó.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative pb-24 md:pb-32">
    <div class="container">
      <div class="card p-10 md:p-14 text-center max-w-4xl mx-auto reveal">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-display tracking-[-0.025em] text-[#0A1931]">
          ¿Tienes un servidor en mente?
        </h2>
        <p class="text-[#4A6A87] mt-5 max-w-xl mx-auto">
          Si necesitas un backend serio para tu servidor de FiveM o algo
          parecido, podemos hablar.
        </p>
        <div class="flex flex-wrap gap-3 mt-8 justify-center">
          <a href="mailto:srangeldev@gmail.com" class="btn btn-primary">Contacto</a>
          <a href="/#proyectos" class="btn btn-secondary">Otros proyectos</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
