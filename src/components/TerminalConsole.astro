---
// Light-themed macOS-style terminal console
---

<div class="terminal-window">
  <!-- Title bar -->
  <div class="terminal-header">
    <div class="terminal-controls">
      <span class="dot dot-red" aria-hidden="true"></span>
      <span class="dot dot-yellow" aria-hidden="true"></span>
      <span class="dot dot-green" aria-hidden="true"></span>
    </div>
    <div class="terminal-title">
      <span class="text-[#4A6A87] text-xs font-mono">~/portfolio — zsh — 80×24</span>
    </div>
    <div class="terminal-spacer"></div>
  </div>

  <!-- Body -->
  <div class="terminal-body font-mono text-sm leading-relaxed">
    <div class="line">
      <span class="prompt">srangel@dev</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span>
      <span class="cmd">whoami</span>
    </div>
    <div class="out">Ángel Sánchez — Desarrollador Full Stack</div>

    <div class="line">
      <span class="prompt">srangel@dev</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span>
      <span class="cmd">cat stack.json</span>
    </div>
    <div class="out">
      <span class="brace">&#123;</span><br />
      &nbsp;&nbsp;<span class="key">"backend"</span>: <span class="str">["C#", ".NET", "Java", "Spring Boot"]</span>,<br />
      &nbsp;&nbsp;<span class="key">"frontend"</span>: <span class="str">["Angular", "TypeScript", "Astro"]</span>,<br />
      &nbsp;&nbsp;<span class="key">"infra"</span>: <span class="str">["Docker", "Nginx", "GitHub Actions"]</span><br />
      <span class="brace">&#125;</span>
    </div>

    <div class="line">
      <span class="prompt">srangel@dev</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span>
      <span class="cmd">echo $STATUS</span>
    </div>
    <div class="out success">● Disponible para proyectos</div>

    <div class="line">
      <span class="prompt">srangel@dev</span><span class="sep">:</span><span class="path">~</span><span class="dollar">$</span>
      <span class="cursor">▊</span>
    </div>
  </div>
</div>

<style>
  .terminal-window {
    width: 100%;
    background: #ffffff;
    border: 1px solid rgba(26, 61, 99, 0.1);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 10px 40px -10px rgba(26, 61, 99, 0.18),
      0 2px 8px -2px rgba(26, 61, 99, 0.08);
  }

  .terminal-header {
    background: linear-gradient(180deg, #f3f8fc 0%, #e8f0f8 100%);
    border-bottom: 1px solid rgba(26, 61, 99, 0.08);
    padding: 10px 14px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  .terminal-controls {
    display: flex;
    gap: 7px;
    align-items: center;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 0 0.5px rgba(0, 0, 0, 0.06);
  }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    text-align: center;
  }

  .terminal-body {
    padding: 22px 24px 26px;
    background: #ffffff;
    color: #0a1931;
  }

  .line {
    margin-top: 0.6em;
  }
  .line:first-child {
    margin-top: 0;
  }

  .prompt { color: #1a3d63; font-weight: 600; }
  .sep    { color: #7895ae; }
  .path   { color: #4a7fa7; }
  .dollar { color: #7895ae; margin: 0 6px 0 2px; }
  .cmd    { color: #0a1931; font-weight: 500; }
  .out    { color: #4a6a87; padding: 4px 0 2px 0; white-space: pre-wrap; }
  .out.success { color: #2f7d4f; font-weight: 500; }
  .brace  { color: #1a3d63; font-weight: 600; }
  .key    { color: #1a3d63; }
  .str    { color: #4a7fa7; }
  .cursor {
    color: #1a3d63;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to { visibility: hidden; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
</style>
