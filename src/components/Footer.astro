---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: "Inicio", url: "/#inicio" },
  { label: "Proyectos", url: "/#proyectos" },
  { label: "Stack", url: "/#stack" },
  { label: "Sobre mí", url: "/sobre-mi" },
];
---

<footer class="relative mt-auto bg-white/70 backdrop-blur-md border-t border-[rgba(26,61,99,0.08)]">
  <div class="container py-12 md:py-14">
    <div class="grid grid-cols-12 gap-8 md:gap-6 items-start">
      <!-- Brand (5/12) -->
      <div class="col-span-12 md:col-span-5 space-y-4">
        <div class="flex items-center gap-2.5">
          <div
            class="w-9 h-9 rounded-lg bg-[#1A3D63] flex items-center justify-center text-white font-bold text-sm shadow-md shadow-[#1A3D63]/15"
          >
            A
          </div>
          <span class="text-lg font-bold font-display tracking-tight text-[#0A1931]">
            Ángel<span class="text-[#4A7FA7]">.</span>dev
          </span>
        </div>
        <p class="text-[#4A6A87] text-sm leading-relaxed max-w-sm">
          Construyo experiencias digitales con código limpio, escalable y pensado para durar.
        </p>
      </div>

      <!-- Navegación (3/12) -->
      <div class="col-span-6 md:col-span-3 space-y-4">
        <h4 class="text-xs font-mono font-semibold text-[#1A3D63] uppercase tracking-[0.14em]">
          Navegación
        </h4>
        <ul class="flex flex-col gap-2.5">
          {
            navLinks.map((l) => (
              <li>
                <a href={l.url} class="text-[#4A6A87] hover:text-[#0A1931] text-sm transition-colors">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Conectar (4/12) -->
      <div class="col-span-6 md:col-span-4 space-y-4">
        <h4 class="text-xs font-mono font-semibold text-[#1A3D63] uppercase tracking-[0.14em]">
          Conectar
        </h4>
        <div class="flex gap-2.5">
          <a
            href="https://github.com/SrAngelDev"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-[#EEF4FA] border border-[rgba(26,61,99,0.08)] flex items-center justify-center text-[#1A3D63] hover:bg-[#1A3D63] hover:text-white hover:border-[#1A3D63] transition-all duration-300"
            aria-label="GitHub"
          >
            <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/srangeldev"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-[#EEF4FA] border border-[rgba(26,61,99,0.08)] flex items-center justify-center text-[#1A3D63] hover:bg-[#1A3D63] hover:text-white hover:border-[#1A3D63] transition-all duration-300"
            aria-label="LinkedIn"
          >
            <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
          <a
            href="mailto:srangeldev@gmail.com"
            class="w-10 h-10 rounded-lg bg-[#EEF4FA] border border-[rgba(26,61,99,0.08)] flex items-center justify-center text-[#1A3D63] hover:bg-[#1A3D63] hover:text-white hover:border-[#1A3D63] transition-all duration-300"
            aria-label="Email"
          >
            <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
        <p class="text-xs text-[#7895AE] leading-relaxed">
          ¿Una idea?
          <a href="mailto:srangeldev@gmail.com" class="text-[#1A3D63] font-medium hover:underline">
            Escríbeme
          </a>.
        </p>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-10 pt-6 border-t border-[rgba(26,61,99,0.08)] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-xs">
      <p class="text-[#7895AE]">
        &copy; {currentYear} Ángel Sánchez · Todos los derechos reservados
      </p>
      <p class="text-[#7895AE] flex flex-wrap items-center gap-1.5">
        Hecho con
        <span class="text-[#1A3D63] font-semibold">Astro</span>·<span class="text-[#1A3D63] font-semibold">Tailwind</span>·<span class="text-[#1A3D63] font-semibold">Three.js</span>
        en
        <a href="https://srangeldev.es" class="text-[#4A7FA7] hover:text-[#1A3D63] transition-colors font-medium">srangeldev.es</a>
      </p>
    </div>
  </div>
</footer>
